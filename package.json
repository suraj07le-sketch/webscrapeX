{
  "name": "web-scrape-x",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "next build --webpack",
    "build:analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next && rm -rf node_modules && rm -rf tmp",
    "clean:cache": "rm -rf .next/cache",
    "db:generate": "supabase gen types typescript --local > lib/database.types.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:studio": "supabase studio",
    "queue:clean": "node scripts/cleanup.js",
    "queue:start": "node scripts/queue-worker.js",
    "health": "curl -f http://localhost:3000/api/health || exit 1",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod"
  },
